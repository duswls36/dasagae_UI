<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 전시회 맞춤 추천 서비스</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap');
        body { font-family: 'Noto Sans KR', sans-serif; background-color: #f1f5f9; }
        .gradient-main { background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4 md:p-8">

    <div class="w-full max-w-2xl bg-white rounded-3xl shadow-2xl overflow-hidden min-h-[550px] flex flex-col justify-between p-6 md:p-10 relative">
        
        <div id="step-1" class="step-view flex flex-col items-center justify-center flex-grow text-center animate__animated animate__fadeIn">
            <div class="w-24 h-24 gradient-main rounded-3xl flex items-center justify-center text-white text-5xl shadow-xl mb-8 animate__animated animate__heartBeat">🎨</div>
            <h1 class="text-3xl font-bold text-gray-900 mb-4 tracking-tight">AI 전시회 맞춤 추천</h1>
            <p class="text-xl text-indigo-600 font-medium mb-2">반갑습니다! ✨</p>
            <p class="text-gray-500 leading-relaxed max-w-sm">
                당신의 과거 관람 취향을 분석하여 현재 진행 중인 가장 완벽한 전시회를 찾아주겠습니다.
            </p>
        </div>

        <div id="step-2" class="step-view hidden flex-col flex-grow animate__animated animate__fadeIn">
            <div class="mb-6">
                <span class="text-xs font-bold inline-block py-1 px-3 uppercase rounded-full text-indigo-600 bg-indigo-50 mb-2">STEP 01</span>
                <h2 class="text-2xl font-bold text-gray-900">이 중에서 마음에 드는 전시를 골라주세요</h2>
                <p class="text-sm text-gray-400 mt-1">예전에 좋았거나 흥미로운 전시를 하나 선택하세요 (과거 데이터 기반)</p>
            </div>
            
            <div id="past-exhibition-list" class="space-y-3 max-h-[300px] overflow-y-auto pr-2 custom-scrollbar flex-grow">
                </div>
        </div>

        <div id="step-3" class="step-view hidden flex-col flex-grow animate__animated animate__fadeIn">
            <div class="mb-6 text-center">
                <span class="text-xs font-bold inline-block py-1 px-3 uppercase rounded-full text-purple-600 bg-purple-50 mb-2">STEP 02</span>
                <h2 class="text-2xl font-bold text-gray-900">전시회에서 추출된 핵심 키워드입니다</h2>
                <p class="text-sm text-gray-400 mt-1">이 속성들을 분석 알고리즘의 매칭 기준으로 사용합니다.</p>
            </div>

            <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100 flex-grow flex flex-col justify-center items-center mb-4">
                <h3 id="selected-title" class="font-bold text-xl text-gray-800 mb-6 text-center border-b pb-2 w-full"></h3>
                <div id="keyword-badges" class="flex flex-wrap gap-2.5 justify-center max-w-md">
                    </div>
            </div>
        </div>

        <div id="step-4" class="step-view hidden flex-col items-center justify-center flex-grow text-center animate__animated animate__fadeIn">
            <div class="relative w-20 h-20 mb-6">
                <div class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75"></div>
                <div class="relative inline-flex rounded-full h-20 w-20 gradient-main items-center justify-center text-white text-2xl font-bold shadow-lg">AI</div>
            </div>
            <h2 class="text-2xl font-bold text-gray-800 mb-2 tracking-tight">당신의 예술 취향 알고리즘 연산 중...</h2>
            <p class="text-indigo-500 font-medium animate-pulse">로딩중입니다. 잠시만 기다려주세요.</p>
        </div>

        <div id="step-5" class="step-view hidden flex-col flex-grow animate__animated animate__fadeIn">
            <div class="mb-6 text-center">
                <span class="text-xs font-bold inline-block py-1 px-3 uppercase rounded-full text-emerald-600 bg-emerald-50 mb-2">MATCH COMPLETE ✨</span>
                <h2 class="text-2xl font-bold text-gray-900">예쁘게 전시회 추천입니다</h2>
                <p class="text-sm text-gray-400 mt-1">분석 결과 취향 매칭 점수가 가장 높은 현재 진행 중인 전시입니다.</p>
            </div>

            <div id="recommended-list" class="space-y-4 max-h-[320px] overflow-y-auto pr-2 custom-scrollbar flex-grow">
                </div>
        </div>

        <div class="mt-6 border-t border-slate-100 pt-5 flex justify-end">
            <button id="next-btn" class="gradient-main text-white font-semibold px-8 py-3.5 rounded-2xl shadow-xl hover:opacity-95 transition-all transform active:scale-95 flex items-center gap-2">
                <span id="btn-text">다음</span>
                <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
        </div>

    </div>

    <script>
        // 1. 과거 전시회 원본 데이터 (exhibition_with_keywords.csv 기반 파싱 및 키워드 매핑)
        const pastExhibitions = [
            { id: 1, title: "다다익선: 즐거운 협연", keywords: ["다다익선", "백남준", "아카이브", "협업", "미디어", "대중예술", "즐거운"] },
            { id: 2, title: "소멸의 시학: 삭는 미술에 대하여", keywords: ["소멸", "삭는 미술", "자본주의 비판", "자연", "에너지", "협력", "시학"] },
            { id: 3, title: "디지털스토리 : 이야기가 필요해", keywords: ["연출", "미디어", "여가 활용", "산책형 전시", "관람 공유", "가상 세계"] },
            { id: 4, title: "MMCA 예술놀이마당", keywords: ["미술관", "풍경", "네트워킹", "단체 방문", "몰입 체험", "체험형 인터랙티브"] },
            { id: 5, title: "동녘에서 거닐다: 동산 박주환 컬렉션 특별전", keywords: ["동산", "박주환", "감각 자극", "오감 체험", "협업 전시", "한국화"] },
            { id: 6, title: "전자적 숲; 소진된 인간", keywords: ["명상하기", "음악", "플레이리스트", "노이즈 캔슬링", "앰비언트", "마음챙김"] }
        ];

        // 2. 현재 전시회 원본 데이터 (26_1_데이터사이언스개론_팀플_현재전시 기반)
        const currentExhibitions = [
            { 
                title: "로드 무비: 1945년 이후 한·일 미술", 
                inst: "국립현대미술관", 
                period: "2026-05-14 ~ 2026-09-27", 
                desc: "한·일 국교정상화 60주년을 계기로 마련된 전시로, 격동의 시대를 거치는 동안 두 나라 예술가들이 낯선 길 위에서 모험을 감행하며 형성해온 관계와 비공식적 연대, 미디어 교류의 역사를 다룹니다.",
                matchingPool: ["미디어", "협업", "아카이브", "네트워킹", "관람 공유", "협력"] // 매칭 비교용 데이터셋
            },
            { 
                title: "오~감각미술관", 
                inst: "국립현대미술관", 
                period: "2026-04-30 ~ 2027-02-21", 
                desc: "눈, 코, 입, 귀, 손 등 인간이 가진 오감을 활짝 열어 현대미술을 자유롭고 역동적으로 체험할 수 있는 참여형 연출 중심의 어린이 및 가족 타겟 친화형 전시입니다.",
                matchingPool: ["감각 자극", "오감 체험", "즐거운", "몰입 체험", "체험형 인터랙티브", "미술관"]
            },
            { 
                title: "방혜자 - 천지에 마음의 빛 뿌리며 간다", 
                inst: "국립현대미술관", 
                period: "2026-05-20 ~ 2026-10-15", 
                desc: "빛의 화가 방혜자가 선사하는 사색과 위로의 평정 미학. 한국화적 뿌리와 서양 미술 기법의 융합을 바탕으로 우주적 신비감과 마음의 치유를 이끌어내는 정적 전시입니다.",
                matchingPool: ["명상하기", "마음챙김", "한국화", "에너지", "자연", "시학", "앰비언트"]
            },
            { 
                title: "청주 미술관 개방 수장고 개편전", 
                inst: "국립현대미술관 청주", 
                period: "상시 진행", 
                desc: "수장고 속 잠들어있던 조각 소장품들을 연대별, 재료별 특성에 맞춰 공간 미학적으로 재배치하고, 관람객들이 보존 환경과 삼차원 입체 예술을 직접 관람하도록 디자인 그룹과 협업한 전시입니다.",
                matchingPool: ["아카이브", "협업", "공간 미학", "조각", "협력", "자본주의 비판"]
            }
        ];

        // 어플리케이션 상태 제어 변수
        let currentStep = 1;
        let selectedPastId = null;

        // DOM 요소 캐싱
        const nextBtn = document.getElementById('next-btn');
        const btnText = document.getElementById('btn-text');
        const btnIcon = document.getElementById('btn-icon');
        const pastListContainer = document.getElementById('past-exhibition-list');
        const keywordBadgesContainer = document.getElementById('keyword-badges');
        const selectedTitleHeader = document.getElementById('selected-title');
        const recommendedListContainer = document.getElementById('recommended-list');

        // 과거 전시 리스트를 화면에 예쁘게 그리기
        function initPastExhibitions() {
            pastListContainer.innerHTML = pastExhibitions.map(ex => `
                <div onclick="selectPast(${ex.id})" id="past-card-${ex.id}" class="group border-2 border-slate-100 rounded-2xl p-4 cursor-pointer hover:bg-indigo-50/40 hover:border-indigo-300 transition-all flex items-center justify-between shadow-sm">
                    <div>
                        <h4 class="font-bold text-gray-800 group-hover:text-indigo-900 transition-colors">${ex.title}</h4>
                        <p class="text-xs text-gray-400 mt-1">주요 태그: ${ex.keywords.slice(0, 4).join(', ')}</p>
                    </div>
                    <div class="radio-circle w-6 h-6 rounded-full border-2 border-slate-200 flex items-center justify-center transition-all">
                        <div class="radio-dot w-3 h-3 rounded-full bg-white transition-all"></div>
                    </div>
                </div>
            `).join('');
        }

        // 특정 과거 전시 카드 클릭 이벤트 핸들러
        window.selectPast = function(id) {
            selectedPastId = id;
            document.querySelectorAll('[id^="past-card-"]').forEach(card => {
                card.classList.remove('border-indigo-500', 'bg-indigo-50/50', 'shadow-md');
                card.classList.add('border-slate-100');
                const dot = card.querySelector('.radio-circle');
                dot.classList.remove('border-indigo-600', 'bg-indigo-600');
            });
            
            const activeCard = document.getElementById(`past-card-${id}`);
            activeCard.classList.remove('border-slate-100');
            activeCard.classList.add('border-indigo-500', 'bg-indigo-50/50', 'shadow-md');
            
            const activeDot = activeCard.querySelector('.radio-circle');
            activeDot.classList.add('border-indigo-600', 'bg-indigo-600');
        }

        // 화면 전환(Step) 메인 트랜지션 엔진
        function navigateTo(step) {
            document.querySelectorAll('.step-view').forEach(el => el.classList.add('hidden'));
            document.getElementById(`step-${step}`).classList.remove('hidden');
            currentStep = step;

            // 스텝 상태에 따른 하단 버튼 레이아웃 제어
            if (currentStep === 1) {
                btnText.innerText = "다음";
                nextBtn.style.display = "flex";
            } else if (currentStep === 2) {
                btnText.innerText = "키워드 추출하기";
                nextBtn.style.display = "flex";
            } else if (currentStep === 3) {
                btnText.innerText = "취향 분석 및 추천 받기";
                nextBtn.style.display = "flex";
            } else if (currentStep === 4) {
                nextBtn.style.display = "none"; // 로딩창에서는 다음 버튼 제거
                // 실제 취향 매칭 연산 처리를 위한 딜레이 타이머 작동 (2.2초 후 다음 스텝 이동)
                setTimeout(() => {
                    runRecommendationEngine();
                    navigateTo(5);
                }, 2200);
            } else if (currentStep === 5) {
                btnText.innerText = "다시 추천 받기";
                btnIcon.style.display = "none";
                nextBtn.style.display = "flex";
            }
        }

        // 선택한 과거 전시 키워드 화면 로드
        function loadKeywords() {
            const data = pastExhibitions.find(ex => ex.id === selectedPastId);
            selectedTitleHeader.innerText = `«${data.title}»`;
            
            keywordBadgesContainer.innerHTML = data.keywords.map((kw, i) => `
                <span class="animate__animated animate__scaleIn inline-block bg-gradient-to-r from-indigo-500 to-purple-500 text-white text-xs font-semibold px-4 py-2 rounded-xl shadow-md transform hover:scale-110 transition-transform" style="animation-delay: ${i * 0.05}s">
                    # ${kw}
                </span>
            `).join('');
        }

        // 핵심 실시간 데이터 매칭 추천 알고리즘 엔진 (자카드 유사도 방식 수학적 연산 모델)
        function runRecommendationEngine() {
            const selectedPastData = pastExhibitions.find(ex => ex.id === selectedPastId);
            const userKeywords = selectedPastData.keywords;

            // 현재 전시회 풀과 하나하나 문자열 키워드 비교 대조 연산 실행
            const scoreResults = currentExhibitions.map(current => {
                const pool = current.matchingPool;
                
                // 교집합(매칭되는 단어 리스트) 추출
                const intersection = userKeywords.filter(kw => pool.includes(kw));
                // 합집합 구하기
                const union = new Set([...userKeywords, ...pool]);
                
                // 수학적 유사도 산출 (교집합 크기 / 합집합 크기)
                let similarity = intersection.length / union.size;
                
                // 퍼센트 스코어로 환산 후 가독성 보정 가중치 추가
                let matchPercent = Math.round(similarity * 100);
                
                // 만약 교집합이 없더라도 최소 기본 흥미 매칭 유연도(40~60%) 랜덤 기본 보정 점수 부여
                if (matchPercent === 0) {
                    matchPercent = Math.floor(Math.random() * 21) + 40;
                } else {
                    matchPercent = matchPercent + 45; // 기반 가중치 스케일 업
                    if (matchPercent > 99) matchPercent = 99; // 상한 크레딧 보정
                }

                return { ...current, score: matchPercent };
            });

            // 매칭 스코어가 가장 높은 추천 전시회 순으로 내림차순 정렬
            scoreResults.sort((a, b) => b.score - a.score);

            // 최종 추천 리스트 UI 뷰 렌더링
            recommendedListContainer.innerHTML = scoreResults.map((item, index) => {
                // 매칭 점수별 뱃지 컬러 동적 변화 분기 처리
                let badgeColor = "bg-emerald-500";
                if(index === 0) badgeColor = "bg-gradient-to-r from-amber-500 to-orange-500 animate-pulse";
                else if (index === 1) badgeColor = "bg-indigo-600";

                return `
                    <div class="animate__animated animate__fadeInUp border border-slate-100 bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-all relative overflow-hidden" style="animation-delay: ${index * 0.15}s">
                        <div class="absolute top-0 right-0 ${badgeColor} text-white text-xs font-bold px-3 py-1.5 rounded-bl-xl shadow-md">
                            ${index === 0 ? '👑 최적 추천' : ''} 매칭률 ${item.score}%
                        </div>
                        
                        <h3 class="text-lg font-bold text-gray-900 pr-24">${item.title}</h3>
                        <p class="text-xs text-indigo-600 font-semibold mt-1">${item.inst} · <span class="text-gray-400 font-normal">${item.period}</span></p>
                        <p class="text-sm text-gray-500 mt-3 leading-relaxed">${item.desc}</p>
                        
                        <div class="flex flex-wrap gap-1 mt-4">
                            ${item.matchingPool.slice(0, 4).map(tag => `<span class="text-[10px] bg-slate-100 text-slate-500 font-medium px-2 py-0.5 rounded-md">#${tag}</span>`).join('')}
                        </div>
                    </div>
                `;
            }).join('');
        }

        // 제어 버튼 이벤트 핸들러 통합 리스너
        nextBtn.addEventListener('click', () => {
            if (currentStep === 1) {
                navigateTo(2);
            } else if (currentStep === 2) {
                if (!selectedPastId) {
                    alert("취향을 분석할 전시회를 리스트에서 꼭 한 개 선택해 주세요!");
                    return;
                }
                loadKeywords();
                navigateTo(3);
            } else if (currentStep === 3) {
                navigateTo(4); // 로딩 스텝으로 전환 -> 타이머 작동 후 5번 최종 스텝으로 오토 토글
            } else if (currentStep === 5) {
                // 애플리케이션 상태 리셋 초기화 루틴
                selectedPastId = null;
                btnIcon.style.display = "inline-block";
                initPastExhibitions();
                navigateTo(1);
            }
        });

        // 웹 브라우저 최초 로드시 데이터 렌더러 구동
        initPastExhibitions();
    </script>
</body>
</html>
